<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_top_section"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_detail_back"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:contentDescription="@string/cd_back"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:text="@string/action_back"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_body_large"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btn_detail_favorite"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/cd_favorite"
                        android:padding="@dimen/spacing_xs"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_favorite_star" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_detail_logo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_portfolio_logo"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo_tesla" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_asset_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_company_name"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_asset_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/detail_subtitle"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_asset_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/asset_price_tesla"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_asset_profit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profit_badge"
                        android:paddingStart="@dimen/spacing_lg"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_lg"
                        android:paddingBottom="@dimen/spacing_sm"
                        android:text="@string/asset_profit_tesla"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_detail_favorite_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_xs"
                    android:text="@string/detail_favorite_out"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorSurface"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xxl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_chart_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="@dimen/spacing_lg">

                    <ImageView
                        android:id="@+id/iv_detail_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/detail_chart_title"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_chart_line_month" />

                    <TextView
                        android:id="@+id/tv_detail_chart_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_profit_badge"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_xs"
                        android:text="@string/detail_chart_change"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_detail_range_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="38dp"
                        android:minHeight="28dp"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/detail_range_1d"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/btn_detail_range_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="38dp"
                        android:minHeight="28dp"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/detail_range_1w"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/btn_detail_range_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:background="@drawable/bg_chip_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="38dp"
                        android:minHeight="28dp"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/detail_range_1m"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_detail_range_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="38dp"
                        android:minHeight="28dp"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/detail_range_1y"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxl"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_current_price"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_stat_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/asset_price_tesla"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_today_change"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_stat_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/detail_static_percent"
                            android:textColor="@color/colorPositive"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="@string/detail_position_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_quantity_label"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_asset_quantity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_qty_tesla"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_total_value_label"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_asset_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_qty_tesla"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/detail_total_profit_label"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_position_profit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_profit_tesla"
                            android:textColor="@color/colorPositive"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_manage_investment"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    android:text="@string/action_manage_investment"
                    android:textAllCaps="false"
                    android:textColor="@color/colorTextPrimary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_detail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</LinearLayout>
