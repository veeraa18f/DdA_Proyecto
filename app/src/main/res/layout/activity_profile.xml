<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xxl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_top_section"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:background="@drawable/bg_chip_selected"
                    android:contentDescription="@string/cd_profile_avatar"
                    android:gravity="center"
                    android:text="@string/profile_avatar_initials"
                    android:textColor="@color/colorBlack"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/profile_name"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/profile_id_label"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_profile_identifier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/profile_id_value"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_edit_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:contentDescription="@string/cd_open_profile_option"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_box_size"
                    android:layout_height="@dimen/icon_box_size"
                    android:background="@drawable/bg_bottom_nav_item_active">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_edit"
                        android:tint="@color/colorBlack" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:text="@string/profile_option_edit"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:contentDescription="@string/cd_open_profile_option"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_box_size"
                    android:layout_height="@dimen/icon_box_size"
                    android:background="@drawable/bg_bottom_nav_item_active">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_language"
                        android:tint="@color/colorBlack" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:text="@string/profile_option_language"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:contentDescription="@string/cd_open_profile_option"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_box_size"
                    android:layout_height="@dimen/icon_box_size"
                    android:background="@drawable/bg_bottom_nav_item_active">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_appearance"
                        android:tint="@color/colorBlack" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:text="@string/profile_option_appearance"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:contentDescription="@string/cd_open_profile_option"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_box_size"
                    android:layout_height="@dimen/icon_box_size"
                    android:background="@drawable/bg_bottom_nav_item_active">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_terms"
                        android:tint="@color/colorBlack" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:text="@string/profile_option_terms"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:contentDescription="@string/cd_open_profile_option"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_box_size"
                    android:layout_height="@dimen/icon_box_size"
                    android:background="@drawable/bg_chip">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_logout"
                        android:tint="@color/colorNegative" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:text="@string/profile_option_logout"
                    android:textColor="@color/colorNegative"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextSecondary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_xxl"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_xxl"
        android:layout_marginBottom="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_profile"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemHorizontalTranslationEnabled="false"
            app:itemIconSize="@dimen/icon_nav_size"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu"
            app:selectedItemId="@id/menu_profile" />
    </FrameLayout>
</LinearLayout>
