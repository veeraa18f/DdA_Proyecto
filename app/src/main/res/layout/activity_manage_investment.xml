<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBlack"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xxl"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:layout_marginEnd="@dimen/spacing_xxl"
            android:background="@drawable/bg_manage_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xxl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_manage_header"
                android:gravity="center"
                android:text="@string/manage_title"
                android:textColor="@color/colorWhite"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_manage_header"
                android:gravity="center"
                android:text="@string/manage_update_mode"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_manage_card"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <ImageView
                        android:id="@+id/iv_manage_logo"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_portfolio_logo"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo_tesla" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_manage_asset_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_company_name"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_manage_asset_meta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/manage_asset_meta_placeholder"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorBlack" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tv_manage_current_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/manage_current_price_placeholder"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_manage_quantity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/manage_quantity_placeholder"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/manage_new_price_label"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/input_manage_price"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_manage_input"
                android:gravity="center_vertical"
                android:inputType="numberDecimal"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:singleLine="true"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body_large" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/manage_new_quantity_label"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/input_manage_quantity"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_manage_input"
                android:gravity="center_vertical"
                android:inputType="numberDecimal"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:singleLine="true"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body_large" />

            <TextView
                android:id="@+id/tv_manage_preview_title"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_manage_card"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_md"
                android:text="@string/manage_preview_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container_manage_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_manage_card"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorBlack" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/manage_preview_value"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_manage_preview_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorBlack" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/manage_preview_profit"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_manage_preview_profit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorBlack" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/manage_preview_return"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_manage_preview_return"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_update_investment"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_manage_update_button"
                android:backgroundTint="@null"
                android:text="@string/action_update_investment"
                android:textAllCaps="false"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_cancel_manage"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_manage_cancel_button"
                android:backgroundTint="@null"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_xxl"
        android:layout_marginEnd="@dimen/spacing_xxl"
        android:layout_marginBottom="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_manage"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</LinearLayout>
