<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xxl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_top_section"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_detail_back"
                        android:layout_width="@dimen/icon_box_size"
                        android:layout_height="@dimen/icon_box_size"
                        android:background="@drawable/bg_chip"
                        android:contentDescription="@string/cd_back"
                        android:padding="@dimen/spacing_md"
                        android:src="@drawable/ic_back"
                        android:tint="@color/colorTextPrimary" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btn_detail_favorite"
                        android:layout_width="@dimen/icon_box_size"
                        android:layout_height="@dimen/icon_box_size"
                        android:background="@drawable/bg_chip"
                        android:contentDescription="@string/cd_toggle_favorite"
                        android:padding="@dimen/spacing_md"
                        android:src="@drawable/ic_star"
                        android:tint="@color/colorTextPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_header_ticker"
                        android:layout_width="@dimen/logo_size"
                        android:layout_height="@dimen/logo_size"
                        android:background="@drawable/bg_chip_selected"
                        android:gravity="center"
                        android:text="@string/detail_ticker"
                        android:textColor="@color/colorBlack"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_company_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_company_name"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_ticker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/detail_ticker"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="@dimen/text_body_large" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:background="@drawable/bg_modal"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <TextView
                        android:id="@+id/tv_detail_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_price"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_headline"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@drawable/bg_profit_badge"
                        android:text="@string/detail_change"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_chart_label"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="98dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="82dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="118dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="132dp"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/detail_chart_placeholder"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_box"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_stat_current_price"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/tv_detail_stat_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/detail_price"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_body_large"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_box"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_stat_today_change"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/tv_detail_stat_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/detail_change"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_body_large"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_position_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_position_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/detail_position_amount"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_position_avg_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/detail_position_avg_price"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_detail_position_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/detail_position_value"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_box"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/manage_value_label"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="@dimen/text_caption" />

                        <TextView
                            android:id="@+id/tv_detail_position_value_card"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/detail_position_value"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_box"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_position_profit_label"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="@dimen/text_caption" />

                        <TextView
                            android:id="@+id/tv_detail_profit_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/detail_position_profit_value"
                            android:textColor="@color/colorPositive"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_box"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_position_return_label"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="@dimen/text_caption" />

                        <TextView
                            android:id="@+id/tv_detail_return_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/detail_position_return_value"
                            android:textColor="@color/colorPositive"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_manage_investment"
                style="@style/Widget.InvestTrack.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/action_manage_investment" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_xxl"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_xxl"
        android:layout_marginBottom="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_detail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemHorizontalTranslationEnabled="false"
            app:itemIconSize="@dimen/icon_nav_size"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</LinearLayout>
