<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_detail_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip"
                android:contentDescription="@string/cd_back"
                android:padding="@dimen/spacing_md"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_weight="1"
                android:text="@string/detail_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_detail_favorite"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cd_favorite"
                android:padding="@dimen/spacing_xs"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_favorite_star" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_top_section"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_xl">

            <ImageView
                android:id="@+id/iv_detail_logo"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/cd_portfolio_logo"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_tesla" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_detail_asset_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_company_name"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_asset_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/detail_subtitle"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body_large" />

                <TextView
                    android:id="@+id/tv_detail_asset_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/asset_price_tesla"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_asset_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/asset_qty_tesla"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body_large" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_asset_quantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_xs"
                        android:text="@string/asset_qty_tesla"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/tv_detail_asset_profit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:background="@drawable/bg_profit_badge"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_xs"
                        android:text="@string/asset_profit_tesla"
                        android:textColor="@color/colorPositive"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_manage_investment"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:text="@string/action_manage_investment"
            android:textAllCaps="false"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_detail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</LinearLayout>
