<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xxl">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manage_title"
        android:textColor="@color/colorTextPrimary"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/manage_subtitle"
        android:textColor="@color/colorTextSecondary"
        android:textSize="@dimen/text_body_large" />

    <EditText
        style="@style/Widget.InvestTrack.EditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:hint="@string/asset_price_tesla"
        android:inputType="numberDecimal" />

    <EditText
        style="@style/Widget.InvestTrack.EditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:hint="@string/asset_qty_tesla"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/btn_update_investment"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:background="@drawable/bg_button_primary"
        android:backgroundTint="@null"
        android:text="@string/action_update_investment"
        android:textAllCaps="false"
        android:textColor="@color/colorTextPrimary"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_cancel_manage"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_button_secondary"
        android:backgroundTint="@null"
        android:text="@string/action_cancel"
        android:textAllCaps="false"
        android:textColor="@color/colorTextPrimary"
        android:textStyle="bold" />
</LinearLayout>
