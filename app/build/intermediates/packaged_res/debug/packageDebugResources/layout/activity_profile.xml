<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xxl">

        <ImageView
            android:id="@+id/iv_profile_photo"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:adjustViewBounds="true"
            android:clickable="true"
            android:contentDescription="@string/cd_profile_photo"
            android:focusable="true"
            android:scaleType="fitCenter"
            android:src="@drawable/profile_photo_1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/profile_title"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/profile_name"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_body_large" />

        <TextView
            android:id="@+id/tv_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/profile_email_default"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/tv_profile_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/profile_phone_default"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_body" />

        <Button
            android:id="@+id/btn_profile_change_photo"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:text="@string/profile_change_photo"
            android:textAllCaps="false"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_profile_edit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_button_secondary"
            android:backgroundTint="@null"
            android:text="@string/profile_option_edit_profile"
            android:textAllCaps="false"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/row_profile_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_option_language"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_profile_language_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_english"
                android:textColor="@color/colorTextSecondary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_profile_dark_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_option_dark_mode"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_profile_dark_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="56dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_profile_logout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_button_secondary"
            android:backgroundTint="@null"
            android:text="@string/profile_option_logout"
            android:textAllCaps="false"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_xxl"
        android:background="@drawable/bg_modal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_profile"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@android:color/transparent"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>
</LinearLayout>
