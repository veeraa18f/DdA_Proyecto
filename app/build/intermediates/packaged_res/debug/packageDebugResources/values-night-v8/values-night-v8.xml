<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="colorBackground">#121212</color>
    <color name="colorBlack">#000000</color>
    <color name="colorBorder">#E5E7EB</color>
    <color name="colorBottomBar">#16211F</color>
    <color name="colorCard">#242424</color>
    <color name="colorCardAlt">#1F2D2A</color>
    <color name="colorFavorite">#FACC15</color>
    <color name="colorHint">#8F9AA8</color>
    <color name="colorIconInactive">#9AA4B2</color>
