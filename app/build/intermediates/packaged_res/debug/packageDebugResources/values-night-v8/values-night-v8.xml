        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorError">@color/colorNegative</item>
        <item name="colorOnError">@color/colorWhite</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBottomBar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorControlNormal">@color/colorTextSecondary</item>
        <item name="colorControlActivated">@color/colorPrimary</item>
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.InvestTrack.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.InvestTrack.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.InvestTrack.Large</item>
