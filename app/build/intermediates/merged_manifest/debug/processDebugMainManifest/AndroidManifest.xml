<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tuempresa.investtrack"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.tuempresa.investtrack.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.tuempresa.investtrack.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="InvestTrack.app.InvestTrackApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/investtrack"
        android:label="@string/app_name"
        android:roundIcon="@drawable/investtrack"
        android:supportsRtl="true"
        android:theme="@style/Theme.InvestTrack" >
        <activity
            android:name="InvestTrack.splash.SplashActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="InvestTrack.manage.ManageInvestmentActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.manage.AddInvestmentActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.detail.DetailActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.profile.EditProfileActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.favorites.FavoritesActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.home.HomeActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.register.RegisterActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.forgot.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name="InvestTrack.login.LoginActivity"
            android:exported="false" />

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.tuempresa.investtrack.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>